.login-shell {
  padding-top: 48rpx;
}

.login-hero {
  background: linear-gradient(135deg, #111827 0%, #0f766e 100%);
  border-radius: 20rpx;
  box-shadow: 0 22rpx 52rpx rgba(15, 23, 42, 0.2);
  color: #ffffff;
  margin-bottom: 24rpx;
  padding: 34rpx 30rpx;
}

.brand-row {
  align-items: center;
  display: flex;
  gap: 20rpx;
}

.brand-mark {
  align-items: center;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 14rpx;
  color: #ffffff;
  display: flex;
  font-size: 34rpx;
  font-weight: 900;
  height: 88rpx;
  justify-content: center;
  width: 88rpx;
}

.auth-panel {
  margin-top: 20rpx;
}
