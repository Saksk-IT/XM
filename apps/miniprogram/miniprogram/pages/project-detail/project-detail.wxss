.create-card {
  margin-bottom: 24rpx;
}

.form-head {
  margin-bottom: 18rpx;
}

.raw-textarea {
  min-height: 176rpx;
}

.draft-error {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
  border-radius: 12rpx;
  color: #b91c1c;
  font-size: 24rpx;
  line-height: 1.5;
  margin-bottom: 16rpx;
  padding: 14rpx 18rpx;
}

.draft-btn {
  margin-bottom: 22rpx;
}

.picker-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 22rpx;
}

.checklist-textarea {
  min-height: 172rpx;
}

.list-panel {
  padding-bottom: 12rpx;
}

.task-count {
  color: #64748b;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 18rpx;
}

.section-scroll {
  margin: 22rpx -24rpx 0;
  padding: 0 24rpx;
  white-space: nowrap;
}

.section-chip {
  align-items: center;
  background: #f8fafc;
  border: 1rpx solid #dbe5ef;
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #475569;
  display: inline-flex;
  font-size: 24rpx;
  font-weight: 800;
  gap: 10rpx;
  margin-right: 12rpx;
  min-height: 68rpx;
  padding: 0 18rpx;
}

.section-chip.active {
  background: #0f766e;
  border-color: #0f766e;
  color: #ffffff;
}

.section-label {
  max-width: 190rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.section-count {
  align-items: center;
  background: rgba(15, 23, 42, 0.08);
  border-radius: 999rpx;
  display: inline-flex;
  font-size: 21rpx;
  justify-content: center;
  min-width: 38rpx;
  padding: 4rpx 10rpx;
}

.section-chip.active .section-count {
  background: rgba(255, 255, 255, 0.18);
}

.overview-strip {
  border-bottom: 1rpx solid #e2e8f0;
  border-top: 1rpx solid #e2e8f0;
  margin-top: 22rpx;
  padding: 22rpx 0;
}

.overview-title {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.overview-desc {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}

.overview-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 18rpx;
}

.overview-metric {
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  min-width: 0;
  padding: 16rpx 12rpx;
}

.overview-value {
  color: #0f766e;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
}

.overview-label {
  color: #64748b;
  font-size: 21rpx;
  line-height: 1.3;
  margin-top: 8rpx;
}

.section-heading {
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 800;
  margin-top: 22rpx;
}

.compact-empty {
  padding: 28rpx 0;
}

.task-card {
  border-top: 1rpx solid #e2e8f0;
  padding: 24rpx 0;
}

.task-card:first-of-type {
  border-top: 0;
}

.task-title {
  color: #0f172a;
  flex: 1;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
  margin-right: 14rpx;
  min-width: 0;
}

.task-desc {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.task-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.type-chip {
  background: #f1f5f9;
  border-radius: 10rpx;
  color: #475569;
  font-size: 22rpx;
  font-weight: 700;
  padding: 7rpx 12rpx;
}

.task-foot {
  color: #94a3b8;
  display: flex;
  font-size: 22rpx;
  justify-content: space-between;
  margin-top: 16rpx;
}
