page {
  background: #eef3f7;
  color: #152033;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  min-height: 100vh;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx;
}

.page-shell {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 24rpx;
}

.hero {
  background: linear-gradient(135deg, #111827 0%, #0f766e 100%);
  border-radius: 18rpx;
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.18);
  box-sizing: border-box;
  color: #ffffff;
  margin-bottom: 24rpx;
  padding: 30rpx;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.74);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
  text-transform: uppercase;
}

.hero-title {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-top: 10rpx;
}

.hero-copy {
  color: rgba(255, 255, 255, 0.76);
  font-size: 25rpx;
  line-height: 1.55;
  margin-top: 12rpx;
}

.hero-grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 24rpx;
}

.hero-metric {
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  min-width: 0;
  padding: 16rpx;
}

.hero-metric-value {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.hero-metric-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 21rpx;
  margin-top: 8rpx;
}

.section {
  margin-bottom: 24rpx;
}

.surface {
  background: #ffffff;
  border: 1rpx solid #d8e2ec;
  border-radius: 14rpx;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.07);
  box-sizing: border-box;
  padding: 24rpx;
}

.surface-quiet {
  background: #f8fafc;
  border: 1rpx solid #dce6ef;
  border-radius: 14rpx;
  box-sizing: border-box;
  padding: 22rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #d8e2ec;
  border-radius: 14rpx;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.07);
  box-sizing: border-box;
  padding: 24rpx;
}

.row {
  align-items: center;
  display: flex;
}

.space-between {
  justify-content: space-between;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.title {
  color: #0f172a;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.25;
}

.subtitle {
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}

.block-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
}

.muted {
  color: #64748b;
}

.btn {
  align-items: center;
  background: #0891b2;
  border-radius: 12rpx;
  color: #ffffff;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  justify-content: center;
  min-height: 84rpx;
  padding: 0 28rpx;
}

.btn::after {
  border: 0;
}

.btn-secondary {
  background: #e6f6fb;
  color: #0e7490;
}

.btn-ghost {
  background: #f1f5f9;
  color: #334155;
}

.btn-danger {
  background: #fee2e2;
  color: #b91c1c;
}

.icon-btn {
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #d8e2ec;
  border-radius: 12rpx;
  color: #0f766e;
  display: flex;
  font-size: 24rpx;
  font-weight: 700;
  justify-content: center;
  margin: 0;
  min-height: 68rpx;
  padding: 0 22rpx;
}

.icon-btn::after {
  border: 0;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  color: #334155;
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.input,
.textarea,
.select-value {
  background: #ffffff;
  border: 1rpx solid #cbd5e1;
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #0f172a;
  font-size: 28rpx;
  min-height: 82rpx;
  padding: 18rpx 20rpx;
  width: 100%;
}

.textarea {
  line-height: 1.5;
  min-height: 156rpx;
}

.segmented-scroll {
  margin: 8rpx -24rpx 0;
  padding: 0 24rpx;
  white-space: nowrap;
}

.segment-chip {
  background: #f1f5f9;
  border-radius: 12rpx;
  color: #475569;
  display: inline-flex;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 12rpx;
  padding: 14rpx 20rpx;
}

.segment-chip.active {
  background: #0f766e;
  color: #ffffff;
}

.status-chip,
.priority-chip {
  border-radius: 10rpx;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 800;
  padding: 7rpx 12rpx;
}

.status-pending {
  background: #fff7ed;
  color: #c2410c;
}

.status-in_progress {
  background: #e0f2fe;
  color: #0369a1;
}

.status-done {
  background: #dcfce7;
  color: #15803d;
}

.priority-high {
  background: #fee2e2;
  color: #b91c1c;
}

.priority-medium {
  background: #fef3c7;
  color: #92400e;
}

.priority-low {
  background: #e0f2fe;
  color: #0369a1;
}

.progress-track {
  background: #e2e8f0;
  border-radius: 999rpx;
  height: 10rpx;
  overflow: hidden;
}

.progress-fill {
  background: #0f766e;
  border-radius: 999rpx;
  height: 100%;
}

.empty {
  color: #64748b;
  font-size: 27rpx;
  padding: 48rpx 20rpx;
  text-align: center;
}

.error {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
  border-radius: 12rpx;
  color: #b91c1c;
  font-size: 26rpx;
  line-height: 1.5;
  margin-bottom: 20rpx;
  padding: 18rpx 20rpx;
}
